    {
      "parameters": {
        "jsCode": "const rawInput = $input.item.json;\n// n8n webhook: payload is at rawInput.body; Vapi direct: rawInput.message\nconst body = rawInput.body || rawInput;\nconst msg = body.message || body;\nconst call = msg.call || {};\nconst customer = call.customer || call.phoneNumber || {};\nconst artifact = msg.artifact || {};\n\nconst callerPhone = (customer.number || customer.phoneNumber || '').replace(/\\s/g, '');\nconst callId = call.id || msg.callId || '';\nconst endedReason = (call.endedReason || msg.endedReason || 'unknown').toLowerCase();\n\nconst startedAt = call.startedAt || null;\nconst endedAt = call.endedAt || null;\nlet durationSeconds = 0;\nif (startedAt && endedAt) {\n  durationSeconds = Math.round((new Date(endedAt) - new Date(startedAt)) / 1000);\n}\n\nconst transcript = msg.transcript || artifact.transcript || call.transcript || '';\nconst summary    = msg.summary    || call.summary    || '';\nconst recordingUrl = artifact.recordingUrl || call.recordingUrl || '';\nconst phoneNumberId = call.phoneNumberId || '';\nconst assistantId   = call.assistantId   || '';\n\nconst missedTriggers = ['no-answer', 'voicemail', 'missed', 'did-not-pick-up', 'no_answer'];\nconst isMissed  = missedTriggers.some(r => endedReason.includes(r));\nconst wasAnswered = durationSeconds > 5 && !isMissed;\n\nreturn [{ json: {\n  callId, callerPhone, phoneNumberId, assistantId,\n  endedReason, durationSeconds, startedAt, endedAt,\n  transcript, summary, recordingUrl, isMissed, wasAnswered\n} }];"
      },
