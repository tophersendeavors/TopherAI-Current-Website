    {
      "parameters": {
        "jsCode": "const callData   = $('Extract Call Data').item.json;\nconst transcript = callData.transcript || '';\nconst summary    = callData.summary    || '';\n\nconst systemPrompt = 'You are an AI assistant that analyzes call transcripts for Topher AI, an AI automation agency. Return ONLY valid JSON with these keys: caller_name, email, business_name, industry, service_interest, pain_point, budget, timeline, preferred_contact, language, caller_type, urgency, extracted_summary. caller_type must be one of: new_lead, existing_client, support_request, partnership, spam, unknown. urgency must be one of: hot, warm, cold, spam. hot = ready to buy within 30 days. warm = interested, vague timeline. cold = exploring only. spam = junk/silence/wrong number.';\n\n// Return as object \u2014 n8n JSON body mode serializes it natively\nreturn [{ json: {\n  openaiRequest: {\n    model: 'gpt-4o-mini',\n    temperature: 0,\n    response_format: { type: 'json_object' },\n    messages: [\n      { role: 'system', content: systemPrompt },\n      { role: 'user',   content: 'Transcript:\\n' + transcript + '\\n\\nVapi Summary:\\n' + summary }\n    ]\n  }\n} }];"
      },
      "id": "cd01dea9-c810-4613-ae99-54eec5fdab59",
      "name": "Build OpenAI Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        368,
        1248
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $vars.OPENAI_API_KEY }}"
            }
