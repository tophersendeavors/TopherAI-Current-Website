      "id": "476ba240-0133-4b98-bd0c-03a3e57ff8b7",
      "name": "Classify with OpenAI",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        592,
        1248
      ]
    },
    {
      "parameters": {
        "jsCode": "const callData = $('Extract Call Data').item.json;\nconst aiRaw    = $input.item.json;\nconst content  = aiRaw?.choices?.[0]?.message?.content || '{}';\n\nlet parsed = {};\ntry { parsed = JSON.parse(content); } catch(e) {\n  parsed = {\n    caller_name: null, email: null, business_name: null,\n    industry: null, service_interest: null, pain_point: null,\n    budget: null, timeline: null, preferred_contact: null,\n    language: 'en', caller_type: 'unknown', urgency: 'cold',\n    extracted_summary: 'Could not parse AI response.'\n  };\n}\n\nreturn [{ json: {\n  ...callData,\n  callerName:       parsed.caller_name       || null,\n  email:            parsed.email             || null,\n  businessName:     parsed.business_name     || null,\n  industry:         parsed.industry          || null,\n  serviceInterest:  parsed.service_interest  || null,\n  painPoint:        parsed.pain_point        || null,\n  budget:           parsed.budget            || null,\n  timeline:         parsed.timeline          || null,\n  preferredContact: parsed.preferred_contact || null,\n  language:         parsed.language          || 'en',\n  callerType:       parsed.caller_type       || 'unknown',\n  urgency:          parsed.urgency           || 'cold',\n  extractedSummary: parsed.extracted_summary || ''\n} }];"
      },
