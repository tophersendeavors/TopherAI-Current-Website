      "id": "13aacbb5-b1fb-476d-abbf-35bfc8b34bbd",
      "name": "Vapi Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        -304,
        1152
      ],
      "webhookId": "53896ef5-c870-4b6a-b6f3-c5a5ac1e22ed"
