      "id": "92504e0b-cb1f-4f46-8a65-03c61bd9c66d",
      "name": "Check Existing Contact",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        -18880,
        8752
      ],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const response = $input.item.json;\n\n// Supabase REST returns an array directly, but n8n might wrap it.\n// Handle all possible shapes:\nlet contacts = [];\nif (Array.isArray(response)) {\n  contacts = response;\n} else if (Array.isArray(response.body)) {\n  contacts = response.body;\n} else if (Array.isArray(response.data)) {\n  contacts = response.data;\n} else if (response && typeof response === 'object' && response.id) {\n  // Single object returned\n  contacts = [response];\n}\n\nconst isReturning = contacts.length > 0;\nconst existingContact = contacts[0] || null;\nconst leadData = $('Parse GPT Score').item.json;\n\nconsole.log('[New or Returning?]', {\n  responseType: Array.isArray(response) ? 'array' : typeof response,\n  contactsFound: contacts.length,\n  isReturning,\n  matchedBy: existingContact \n    ? (existingContact.phone === leadData.phone ? 'phone' \n       : existingContact.email === leadData.email ? 'email' \n       : 'unknown')\n    : 'no match'\n});\n\nreturn [{ json: {\n  ...leadData,\n  isReturning,\n  existingContact,\n  firstSeenAt: existingContact?.created_at || null\n} }];"
      },
      "id": "952e3fca-a202-4207-9c19-6edfba6ab3f8",
      "name": "New or Returning?",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -18656,
        8752
      ]
    },
    {
      "parameters": {
