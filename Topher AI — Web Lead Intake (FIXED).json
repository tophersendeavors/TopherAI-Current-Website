      "parameters": {
        "url": "={{ $vars.SUPABASE_URL }}/rest/v1/contacts?{{ $json.phone ? 'phone=eq.' + $json.phone : 'email=eq.' + encodeURIComponent($json.email) }}&select=id,phone,email,name,created_at&limit=1",
