      "parameters": {
        "jsCode": "const lead = $('Build Re-engagement Messages').item.json;\n\n// Skip SMS for Spanish leads - we don't send automated SMS to international numbers\nif (lead.language === 'es') {\n  console.log('[Has Phone? Returning] Skipping SMS: Spanish lead');\n  return [];\n}\n\n// Skip if no phone\nif (!lead.phone) {\n  console.log('[Has Phone? Returning] Skipping SMS: no phone');\n  return [];\n}\n\nreturn [{ json: lead }];"
      },
