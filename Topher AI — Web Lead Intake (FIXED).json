    {
      "parameters": {
        "jsCode": "const body = $input.item.json.body || $input.item.json;\n\nconst roleLabels = {\n  'real-estate-solo': 'Solo Real Estate Agent',\n  'real-estate-team': 'Team Lead / Broker',\n  'med-spa':          'Med Spa / Aesthetic Clinic',\n  'legal':            'Legal / Law Firm',\n  'contractor':       'Contractor / Home Services',\n  'insurance':        'Insurance Agent',\n  'other':            'Other'\n};\n\nconst role = body.role || body.industry || '';\nconst industryLabel = roleLabels[role] || role || 'Not specified';\n\nconst name   = (body.name  || '').trim();\nconst email  = (body.email || '').trim();\nconst phone  = (body.phone || '').trim().replace(/[^\\d+]/g, '') || null;\nconst source = body.source || body.source_form || 'website_form';\nconst businessName = (body.business_name || body.spa || '').trim();\nconst locations = body.locations || '';\nconst city = (body.city || '').trim();\nconst painPoint = (body.pain_point || body.pain || '').trim();\n\n// Language detection \u2014 explicit flag from form, or inferred from source\nlet language = (body.language || '').toLowerCase();\nif (!language) {\n  if (source.includes('_es') || source.includes('spanish')) language = 'es';\n  else language = 'en';\n}\n\nlet normalizedPhone = phone;\nif (phone && !phone.startsWith('+')) {\n  const digits = phone.replace(/\\D/g, '');\n  normalizedPhone = digits.length === 10 ? '+1' + digits : '+' + digits;\n}\n\nconst firstName = name.split(' ')[0] || name;\n\nreturn [{ json: {\n  name, firstName, email,\n  phone: normalizedPhone,\n  industry: industryLabel,\n  industryKey: role,\n  source,\n  language,\n  businessName,\n  locations,\n  city,\n  painPoint,\n  leadStatus: 'new',\n  serviceInterest: 'AI receptionist consultation',\n  createdAt: new Date().toISOString()\n} }];"
      },
      "id": "4228ef06-d21c-4eb5-9bd2-3a188f173167",
      "name": "Extract Lead Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -19552,
        8752
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.openai.com/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $vars.OPENAI_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\n  \"model\": \"gpt-4o-mini\",\n  \"temperature\": 0.5,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are Riley, the AI sales assistant for Topher AI (an AI receptionist for service businesses). You score inbound leads and write a SHORT, conversational first SMS opener. Respond ONLY with valid JSON. No markdown, no preamble.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Score this lead and write a SHORT SMS opener.\\n\\nName: \" + $json.name + \"\\nIndustry: \" + $json.industry + \"\\nSource: website contact form\\n\\n# SCORING\\n- hot: Med Spa, Team Lead/Broker, Legal, Insurance, Dental, HVAC, Roofing\\n- warm: Solo Agent, Contractor, general interest\\n- cold: vague, low fit, likely spam\\n\\n# OUTREACH RULES (CRITICAL)\\nWrite ONE short SMS opener (max 1 sentence, max 20 words). Casual, warm, NOT salesy.\\n\\nNEVER use these phrases:\\n- I see you're in X industry\\n- I'd love to / I would love to\\n- Discuss / chat about how we can\\n- Elevate / transform / unlock / streamline\\n- Your success / your business\\n- Synergy / leverage / opportunity\\n\\nGOOD examples (use first name, sound human):\\n- hey [first name] - chris here, got your form, what's the biggest call/lead issue right now?\\n- hey [first name] - just saw you came in from the site, what's eating your time most these days?\\n- [first name] - thanks for reaching out. quick - how are you handling calls/dms right now?\\n\\nBAD examples (NEVER write like this):\\n- Hi [name], I see you're in the [industry] industry and I'd love to discuss how we can elevate your business.\\n- Hello [name], I noticed you reached out and would love to explore how Topher AI can transform your operations.\\n\\nKeep it casual lowercase. Don't capitalize first letters of sentences unnecessarily. Use first name only.\\n\\n# OUTPUT\\nReturn ONLY this JSON:\\n{\\\"urgency\\\": \\\"hot|warm|cold\\\", \\\"outreach\\\": \\\"the short opener\\\", \\\"reason\\\": \\\"one line scoring reason\\\"}\"\n    }\n  ]\n} }}",
        "options": {}
      },
      "id": "147cdcb0-798a-473f-a138-b816c3ab4e76",
      "name": "Score Lead with GPT-4o",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        -19328,
        8752
      ]
    },
    {
      "parameters": {
        "jsCode": "const lead = $('Extract Lead Data').item.json;\nconst gptRaw = $input.item.json;\n\nlet urgency = 'warm', outreach = '', reason = '';\ntry {\n  const content = gptRaw.choices?.[0]?.message?.content || '{}';\n  const cleaned = content.replace(/```json\\n?/g,'').replace(/```\\n?/g,'').trim();\n  const parsed = JSON.parse(cleaned);\n  urgency  = ['hot','warm','cold'].includes(parsed.urgency) ? parsed.urgency : 'warm';\n  outreach = parsed.outreach || '';\n  reason   = parsed.reason   || '';\n} catch(e) {}\n\n// Defensive: normalize language to string, lowercased\nconst language = String(lead.language || 'en').toLowerCase().trim();\n\nreturn [{ json: {\n  ...lead,\n  language,\n  businessName: lead.businessName || '',\n  locations: lead.locations || '',\n  city: lead.city || '',\n  painPoint: lead.painPoint || '',\n  source: lead.source || 'website_form',\n  urgency,\n  outreach,\n  reason\n} }];"
      },
      "id": "ab89c958-3b00-41f4-b618-58deb988cbde",
      "name": "Parse GPT Score",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -19104,
        8752
      ]
    },
