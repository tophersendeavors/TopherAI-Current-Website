    {
      "parameters": {
        "jsCode": "const lead = $('Returning or New?').item.json;\nconst language = lead.language || 'en';\nconst firstName = lead.name ? lead.name.split(' ')[0] : 'there';\nconst industry = (lead.industry && lead.industry !== 'Not specified') ? lead.industry : 'your business';\nconst firstSeen = lead.firstSeenAt ? new Date(lead.firstSeenAt).toLocaleDateString('en-US', {month:'short', day:'numeric'}) : 'recently';\n\nlet leadSms;\n\nif (lead.source === 'vapi-voice-demo') {\n  // They just finished a voice call and typed their number to get the link \u2014 send it immediately\n  leadSms = `Hey ${firstName}! Great talking \u2014 here's the booking link:\\nhttps://cal.com/christopher-wrgldt/topher-ai-demo-call\\n\\n\u2014 Topher AI\\n\\nReply STOP to opt out.`;\n} else {\n  leadSms = `Hey ${firstName}! Looks like you checked out Topher AI again \u2014 glad you're still interested. Chris has time this week to show you exactly how the AI receptionist would work for ${industry}. Want me to send you the booking link? \u2014 Topher AI`;\n}\n\nconst adminSms = `\ud83d\udd04 RETURNING LEAD\\n\\nName: ${lead.name || 'Unknown'}\\nPhone: ${lead.phone || 'N/A'}\\nEmail: ${lead.email || 'N/A'}\\nIndustry: ${lead.industry || 'N/A'}\\nScore: ${(lead.urgency||'warm').toUpperCase()}\\nFirst seen: ${firstSeen}\\nReason: ${lead.reason || ''}`;\n\nreturn [{ json: { language, ...lead, leadSms, adminSms } }];"
      },
      "id": "57b63ca0-7112-4b6a-b378-a3954a4bceff",
      "name": "Build Re-engagement Messages",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -17760,
        8464
      ]
    },
    {
      "parameters": {
        "fromEmail": "cs@topherai.com",
        "toEmail": "cs@topherai.com",
        "subject": "=\ud83d\udd04 Returning Lead \u2014 {{ $('Parse GPT Score').item.json.name }}",
        "html": "=<div style=\"font-family:Arial,sans-serif;max-width:600px;margin:0 auto\">\n<div style=\"background:linear-gradient(135deg,#7c3aed,#a855f7);padding:24px;text-align:center\">\n  <h1 style=\"color:#fff;margin:0;font-size:20px\">\ud83d\udd04 Returning Lead</h1>\n  <p style=\"color:rgba(255,255,255,0.85);margin:6px 0 0;font-size:13px\">This person submitted a form before</p>\n</div>\n<div style=\"padding:24px;background:#fff;border:1px solid #e2e8f0\">\n  <h2 style=\"margin:0 0 16px;font-size:18px\">{{ $('Parse GPT Score').item.json.name }}</h2>\n  <table style=\"width:100%;border-collapse:collapse;font-size:14px\">\n    <tr><td style=\"padding:8px 0;color:#64748b;width:120px\">Email</td>\n        <td><a href=\"mailto:{{ $('Parse GPT Score').item.json.email }}\" style=\"color:#0284c7;font-weight:600\">{{ $('Parse GPT Score').item.json.email }}</a></td></tr>\n    <tr><td style=\"padding:8px 0;color:#64748b\">Phone</td>\n        <td>{{ $('Parse GPT Score').item.json.phone || 'Not provided' }}</td></tr>\n    <tr><td style=\"padding:8px 0;color:#64748b\">Industry</td>\n        <td>{{ $('Parse GPT Score').item.json.industry }}</td></tr>\n    <tr><td style=\"padding:8px 0;color:#64748b\">Score</td>\n        <td style=\"font-weight:700;color:#7c3aed\">{{ $('Parse GPT Score').item.json.urgency.toUpperCase() }}</td></tr>\n  </table>\n  <div style=\"margin-top:20px;padding:16px;background:#faf5ff;border-radius:8px;border-left:4px solid #a855f7\">\n    <p style=\"margin:0;color:#581c87;font-weight:600\">Still interested \u2014 worth a personal follow-up today.</p>\n  </div>\n</div>\n</div>",
        "options": {}
      },
