    {
      "parameters": {
        "jsCode": "const lead = $('Returning or New?').item.json;\nconst firstName = lead.name ? lead.name.split(' ')[0] : 'there';\nconst industry = lead.industry || 'your business';\nconst firstSeen = lead.firstSeenAt ? new Date(lead.firstSeenAt).toLocaleDateString('en-US', {month:'short', day:'numeric'}) : 'recently';\n\nconst leadSms = `Hey ${firstName}! Looks like you checked out Topher AI again \u2014 glad you\\'re still interested. Chris has time this week to show you exactly how the AI receptionist would work for ${industry}. Want me to send you the booking link? \u2014 Topher AI`;\n\nconst adminSms = `\ud83d\udd04 RETURNING LEAD\\n\\nName: ${lead.name || 'Unknown'}\\nPhone: ${lead.phone || 'N/A'}\\nEmail: ${lead.email || 'N/A'}\\nIndustry: ${lead.industry || 'N/A'}\\nScore: ${(lead.urgency||'warm').toUpperCase()}\\nFirst seen: ${firstSeen}\\nReason: ${lead.reason || ''}`;\n\nreturn [{ json: { ...lead, leadSms, adminSms } }];"
      },
