{
  "name": "Topher AI — Inbound SMS Handler",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "topherai-inbound-sms",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "9a9eb853-d9f9-46a4-b98e-5707877cf6ca",
      "name": "Inbound SMS Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        0,
        272
      ],
      "webhookId": "inbound-sms-intake"
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { \"success\": true } }}",
        "options": {
          "responseCode": 200
        }
      },
      "id": "7506d7e2-b3ea-473f-8bb2-0f840f0f0b92",
      "name": "Respond OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        224,
        176
      ]
    },
    {
      "parameters": {
        "jsCode": "const body = $input.item.json.body || $input.item.json;\n\n// Telnyx wraps data in body.data or root level\nconst data    = body.data || body;\nconst payload = data.payload || data;\n\nconst from    = payload.from?.phone_number || payload.from || '';\nconst to      = payload.to?.[0]?.phone_number || payload.to || '';\nconst text    = payload.text || payload.body || payload.message || '';\nconst msgId   = payload.id || data.id || '';\n\n// Normalize to E.164\nlet fromNorm = from.trim();\nif (fromNorm && !fromNorm.startsWith('+')) {\n  const d = fromNorm.replace(/\\D/g,'');\n  fromNorm = d.length === 10 ? '+1' + d : '+' + d;\n}\n\nif (!fromNorm || !text) {\n  // Still return a passthrough so downstream nodes can see what came in\n  return [{ json: { from: fromNorm || 'unknown', to, text: text || '', msgId, receivedAt: new Date().toISOString(), parseError: true } }];\n}\n\nreturn [{ json: { from: fromNorm, to, text, msgId, receivedAt: new Date().toISOString(), parseError: false } }];"
      },
      "id": "513a3d5c-0420-42db-b78f-4222119303bc",
      "name": "Parse Inbound SMS",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        224,
        368
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 1
          },
          "conditions": [
            {
              "id": "no-parse-error",
              "leftValue": "={{ $json.parseError }}",
              "rightValue": false,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "1e71405e-5725-4172-99f3-c801adbbabb5",
      "name": "Has Valid Message?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        448,
        368
      ]
    },
    {
      "parameters": {
        "url": "={{ $vars.SUPABASE_URL }}/rest/v1/contacts",
        "sendQuery": true,
        "queryParameters": {
