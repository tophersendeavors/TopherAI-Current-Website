              "value": "=Bearer {{ $vars.SUPABASE_SERVICE_KEY }}"
            }
          ]
        },
        "options": {}
      },
      "id": "9a4f237e-3063-4de1-a388-684b29584546",
      "name": "Lookup Contact",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        672,
        368
      ]
    },
    {
      "parameters": {
        "jsCode": "const inbound  = $('Parse Inbound SMS').item.json;\nconst contacts = $input.item.json;\n\n// contacts is an array from Supabase\nconst arr     = Array.isArray(contacts) ? contacts : [];\nconst contact = arr[0] || null;\n\nconst name       = contact?.name || 'Unknown Lead';\nconst email      = contact?.email || '';\nconst urgency    = contact?.urgency || 'unknown';\nconst leadStatus = contact?.lead_status || 'unknown';\n\nconst urgencyEmoji = urgency === 'hot' ? '🔥' : urgency === 'warm' ? '⚡' : urgency === 'cold' ? '❄️' : '💬';\n\nconst alertText = `${urgencyEmoji} INBOUND REPLY\\n\\nFrom: ${name}\\nPhone: ${inbound.from}\\nStatus: ${leadStatus}\\n\\nMessage:\\n\"${inbound.text}\"`;\n\nreturn [{ json: {\n  ...inbound,\n  name,\n  email,\n  urgency,\n  leadStatus,\n  urgencyEmoji,\n  alertText\n} }];"
      },
      "id": "14e4c1a7-ee07-4520-ab01-01ae0cb06830",
