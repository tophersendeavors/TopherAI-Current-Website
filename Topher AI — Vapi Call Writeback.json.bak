      "id": "8991f467-89ac-4056-9c2a-91c0b65356bf",
      "name": "Route by Outcome",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [
        -4816,
        5264
      ]
    },
    {
      "parameters": {
        "jsCode": "const d = $('Decide Outcome').item.json;\nconst first = d.firstName || 'there';\nconst firstEs = d.firstName || 'amigo';\nconst sumShort = (d.summary || '').slice(0, 200);\nconst biz = d.extracted.business_name || (d.extracted.industry ? d.extracted.industry.replace(/_/g, ' ') + ' (name not given)' : 'Unknown');\nconst langTag = d.language === 'es' ? '🇪🇸 SPANISH CALL — ' : '';\nconst alertText = `🎯 ${langTag}BOOKED ON CALL\\n\\n${d.customerName || 'Unknown'}\\n${d.customerPhone}\\nBiz: ${biz}\\nPain: ${d.extracted.pain_point || 'Unknown'}\\nDuration: ${d.durationSec}s\\n\\n${sumShort}`.slice(0, 1400);\nlet leadSms;\nif (d.language === 'es') { leadSms = `hola ${firstEs} — ¡qué chévere hablar contigo! aquí está el link de agendamiento para que asegures tu hora:\\n\\nhttps://cal.com/christopher-wrgldt/topher-ai-demo-call\\n\\nchristopher va a ver tu reserva y te contactará. ¡hablamos pronto! 🎯`; } else { leadSms = `hey ${first} — great chatting just now! sending the booking link so you can lock in a time:\\n\\nhttps://cal.com/christopher-wrgldt/topher-ai-demo-call\\n\\nchris will see your booking and reach out. talk soon 🎯`; }\nreturn [{ json: { ...d, alertText, leadSms } }];"
      },
      "id": "82650da0-d855-4890-90ce-691d2eda0f15",
      "name": "Build Booked Alert",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -4592,
        4832
      ]
    },
    {
      "parameters": {
        "jsCode": "const d = $('Decide Outcome').item.json;\nconst first = d.firstName || 'there';\nconst firstEs = d.firstName || 'amigo';\nconst reason = (d.extracted.escalate_reason || 'flagged for human follow-up').slice(0, 150);\nconst sumShort = (d.summary || '').slice(0, 200);\nconst biz = d.extracted.business_name || (d.extracted.industry ? d.extracted.industry.replace(/_/g, ' ') + ' (name not given)' : 'Unknown');\nconst langTag = d.language === 'es' ? '🇪🇸 SPANISH CALL — ' : '';\nconst alertText = `🔥 ${langTag}CALL NEEDS YOU\\n\\n${d.customerName || 'Unknown'}\\n${d.customerPhone}\\nBiz: ${biz}\\nLocations: ${d.extracted.num_locations || '?'}\\n\\nReason: ${reason}\\n\\nSummary: ${sumShort}\\n\\nDuration: ${d.durationSec}s\\n${d.recordingUrl ? 'Recording: ' + d.recordingUrl : ''}`.slice(0, 1400);\nlet leadSms;\nif (d.language === 'es') { leadSms = `hola ${firstEs} — gracias por la llamada. christopher te va a contactar directamente dentro de la próxima hora para conversar más. ¡hablamos pronto! 👋`; } else { leadSms = `hey ${first} — appreciate the call. chris will reach out to you directly within the hour to dig in. talk soon 👋`; }\nreturn [{ json: { ...d, alertText, leadSms } }];"
      },
      "id": "2a9c05bd-59a6-47f0-b95b-357f83d6a4fa",
      "name": "Build Escalation Alert",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -4592,
        5072
      ]
    },
    {
      "parameters": {
        "jsCode": "const d = $('Decide Outcome').item.json;\nconst first = d.firstName || 'there';\nconst firstEs = d.firstName || 'amigo';\nconst sumShort = (d.summary || '').slice(0, 200);\nconst biz = d.extracted.business_name || (d.extracted.industry ? d.extracted.industry.replace(/_/g, ' ') + ' (name not given)' : 'Unknown');\nconst langTag = d.language === 'es' ? '🇪🇸 SPANISH CALL — ' : '';\nconst alertText = `⚡ ${langTag}QUALIFIED — NO BOOK\\n\\n${d.customerName || 'Unknown'}\\n${d.customerPhone}\\nBiz: ${biz}\\nPain: ${d.extracted.pain_point || 'Unknown'}\\nDuration: ${d.durationSec}s\\n\\n${sumShort}\\n\\nCal.com link sent automatically.`.slice(0, 1400);\nlet leadSms;\nif (d.language === 'es') { leadSms = `hola ${firstEs} — qué bueno hablar contigo. aquí está el link para agendar una hora con christopher cuando estés listo:\\n\\nhttps://cal.com/christopher-wrgldt/topher-ai-demo-call\\n\\nsin apuros, son 2 minutos para reservar 🎯`; } else { leadSms = `hey ${first} — great chat. here's the link to grab a time with chris when you're ready:\\n\\nhttps://cal.com/christopher-wrgldt/topher-ai-demo-call\\n\\nno rush, takes 2 min to book 🎯`; }\nreturn [{ json: { ...d, alertText, leadSms } }];"
      },
      "id": "4cf83039-f386-491e-a5de-fa40a84a98c7",
      "name": "Build Qualified Followup",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -4592,
        5312
      ]
    },
    {
      "parameters": {
        "jsCode": "const d = $('Decide Outcome').item.json;\nconst first = d.firstName || 'there';\nconst firstEs = d.firstName || 'amigo';\nconst langTag = d.language === 'es' ? '🇪🇸 SPANISH CALL — ' : '';\nconst alertText = `❄️ ${langTag}NO ANSWER\\n\\n${d.customerName || 'Unknown'}\\n${d.customerPhone}\\nEnded: ${d.endedReason}\\nDuration: ${d.durationSec}s`.slice(0, 1400);\nlet leadSms;\nif (d.language === 'es') { leadSms = `hola ${firstEs} — sofía aquí de topher AI, te llamé hace un momento. tranquilo, puedes responder este mensaje cuando quieras o agendar una llamada rápida con christopher: https://cal.com/christopher-wrgldt/topher-ai-demo-call`; } else { leadSms = `hey ${first} — riley from topher AI here, just tried you. no worries, text me back anytime or grab a quick call with chris: https://cal.com/christopher-wrgldt/topher-ai-demo-call`; }\nreturn [{ json: { ...d, alertText, leadSms } }];"
      },
      "id": "67684d8e-ca22-458b-8bf8-90b318eba7c6",
      "name": "Build No-Answer Followup",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -4592,
        5504
      ]
    },
    {
      "parameters": {
        "jsCode": "const d = $('Decide Outcome').item.json;\nconst first = d.firstName || 'there';\nconst firstEs = d.firstName || 'amigo';\nconst sumShort = (d.summary || '').slice(0, 200);\nconst biz = d.extracted.business_name || (d.extracted.industry ? d.extracted.industry.replace(/_/g, ' ') + ' (name not given)' : 'Unknown');\nconst langTag = d.language === 'es' ? '🇪🇸 SPANISH CALL — ' : '';\nconst alertText = `💬 ${langTag}CALL COMPLETED — NURTURE\\n\\n${d.customerName || 'Unknown'}\\n${d.customerPhone}\\nBiz: ${biz}\\nStatus: ${d.leadStatus}\\nDuration: ${d.durationSec}s\\n\\n${sumShort}`.slice(0, 1400);\nlet leadSms;\nif (d.language === 'es') { leadSms = `hola ${firstEs} — gracias por la llamada. aquí está un link de demo + agendamiento cuando estés listo:\\n\\nhttps://cal.com/christopher-wrgldt/topher-ai-demo-call\\n\\nsin presión, puedes responder este mensaje cuando quieras 👋`; } else { leadSms = `hey ${first} — thanks for the call. here's a quick demo + booking link whenever you're ready:\\n\\nhttps://cal.com/christopher-wrgldt/topher-ai-demo-call\\n\\nno pressure, text this number anytime 👋`; }\nreturn [{ json: { ...d, alertText, leadSms } }];"
      },
      "id": "ab2a8dfd-0f10-4ffe-99d2-15de6b7aecfe",
      "name": "Build Nurture Followup",
