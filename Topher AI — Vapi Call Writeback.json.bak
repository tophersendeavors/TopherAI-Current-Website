    {
      "parameters": {
        "url": "={{ $vars.SUPABASE_URL }}/rest/v1/contacts",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "phone",
              "value": "=eq.{{ $json.customerPhone }}"
            },
            {
              "name": "select",
              "value": "id,name,phone,business_name,industry,pain_point,urgency,lead_status,call_count"
            },
            {
              "name": "limit",
              "value": "1"
            }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $vars.SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $vars.SUPABASE_SERVICE_KEY }}"
            }
          ]
        },
        "options": {}
      },
      "id": "8a7a9dfd-307f-4e7f-8372-b84e92d73c34",
      "name": "Fetch Contact",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        -5712,
        5168
      ],
      "alwaysOutputData": true,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const callData = $('Parse Vapi Payload').item.json;\nconst isAnonymousWeb = callData.isWebCall && callData.customerPhone.startsWith('web:');\nconst contactsArr = $input.item.json;\nconst existingContact = (Array.isArray(contactsArr) && contactsArr.length > 0) ? contactsArr[0] : null;\nconst ex = callData.extracted;\n\nlet urgency = 'warm';\nif (ex.booked) { urgency = 'hot'; }\nelse if (ex.qualified) { urgency = 'hot'; }\nelse if (ex.escalate) { urgency = 'hot'; }\nelse if (!callData.wasAnswered) { urgency = existingContact?.urgency || 'warm'; }\nelse if (ex.sentiment === 'negative') { urgency = 'cold'; }\n\nlet leadStatus = 'contacted';\nif (ex.booked) { leadStatus = 'demo_scheduled'; }\nelse if (ex.qualified) { leadStatus = 'qualified'; }\nelse if (!callData.wasAnswered) { leadStatus = 'attempted'; }\nelse if (ex.sentiment === 'negative' || ex.next_action === 'dead') { leadStatus = 'dead'; }\nelse { leadStatus = 'contacted'; }\n\nconst contactUpdate = {\n  urgency,\n  lead_status: leadStatus,\n  last_call_at: callData.endedAt || new Date().toISOString(),\n  last_call: callData.endedAt || new Date().toISOString(),\n  call_count: (existingContact?.call_count || 0) + 1,\n  updated_at: new Date().toISOString()\n};\nif (callData.customerName)  contactUpdate.name = callData.customerName;\nif (ex.business_name)       contactUpdate.business_name = ex.business_name;\nif (ex.industry)            contactUpdate.industry = ex.industry;\nif (ex.pain_point)          contactUpdate.pain_point = ex.pain_point;\nif (ex.service_interest)    contactUpdate.service_interest = ex.service_interest;\nif (ex.budget)              contactUpdate.budget = ex.budget;\nif (ex.timeline)            contactUpdate.timeline = ex.timeline;\nif (callData.language)      contactUpdate.language = callData.language;\n\nlet branch = 'nurture';\nif (!callData.wasAnswered)              branch = 'no_answer';\nelse if (ex.booked)                     branch = 'booked';\nelse if (ex.escalate)                   branch = 'escalate';\nelse if (ex.qualified)                  branch = 'qualified_no_book';\nelse if (leadStatus === 'dead')         branch = 'dead';\nelse                                     branch = 'nurture';\n\nreturn [{ json: {\n  ...callData,\n  existingContact,\n  contactExists: !!existingContact,\n  contactUpdate,\n  branch,\n  urgency,\n  leadStatus\n} }];"
      },
      "id": "17939dbe-f1d3-4903-aaa8-2c13732e1db5",
