{
  "name": "Topher AI — Vapi Call Writeback",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "topherai-vapi-writeback",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "91d040ed-6ebe-4001-ace1-de7485662a49",
      "name": "Vapi End-of-Call Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        -6384,
        4976
      ],
      "webhookId": "231d0e0b-3b98-4e98-bba4-ec12d609353b"
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { \"success\": true } }}",
        "options": {
          "responseCode": 200
        }
      },
      "id": "844279f2-a8c4-40a9-b391-42aea916adaa",
      "name": "Respond OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        -6160,
        4880
      ]
    },
    {
      "parameters": {
        "jsCode": "// Helper: normalize string \"null\" / empty / undefined to actual null\nconst norm = (v) => {\n  if (v === null || v === undefined) return null;\n  if (typeof v !== 'string') return v;\n  const t = v.trim().toLowerCase();\n  if (t === '' || t === 'null' || t === 'undefined' || t === 'n/a' || t === 'none') return null;\n  return v;\n};\n\nconst body = $input.item.json.body || $input.item.json;\nconst msg = body.message || body;\n\nconst eventType = msg.type || '';\nif (eventType && eventType !== 'end-of-call-report') {\n  return [{ json: { skip: true, reason: 'not end-of-call event: ' + eventType } }];\n}\n\nconst call = msg.call || {};\nconst customer = call.customer || {};\nconst analysis = msg.analysis || {};\nconst structured = analysis.structuredData || {};\n\nconst callId = call.id || msg.callId || '';\nconst customerPhone = customer.number || msg.customer?.number || '';\nconst customerName = customer.name || msg.customer?.name || '';\n\nconst callMetadata = call.metadata || msg.metadata || {};\nconst webSource = callMetadata.source || '';\nconst SOFIA_ID = 'a91daf92-a477-46ed-b4cf-3e8df3a92699';\nconst RILEY_ID = '6e9f5b0d-bb8b-4409-974a-557f78f62172';\n\nconst assistantId = call.assistantId \n  || msg.assistantId \n  || msg.assistant?.id \n  || call.assistant?.id \n  || '';\n\nconst artifact = msg.artifact || call.artifact || {};\nconst messages = artifact.messagesOpenAIFormatted || artifact.messages || msg.messages || [];\n\nconst lastFew = (Array.isArray(messages) ? messages : []).slice(-5);\nconst recentText = lastFew.map(m => (m.content || m.message || '')).join(' ').toLowerCase();\nconst transcriptLower = (msg.transcript || '').toLowerCase();\n\n// Language is determined ONLY by which assistant handled the call.\n// Sofia (SOFIA_ID) = Spanish. Everyone else = English.\n// The previous hasSpanishContent keyword check was causing false positives:\n// Riley's own system prompt and handoff phrases contain 'en español',\n// which caused English calls to be misclassified as Spanish.\nlet language = 'en';\nif (assistantId === SOFIA_ID) {\n  language = 'es';\n}\n\nconst webPage = callMetadata.page || '';\nconst isWebCall = webSource.startsWith('website_');\nconst startedAt = call.startedAt || msg.startedAt || null;\nconst endedAt = call.endedAt || msg.endedAt || null;\nconst endedReason = call.endedReason || msg.endedReason || '';\nconst durationSec = Math.round(msg.durationSeconds || (startedAt && endedAt ? (new Date(endedAt) - new Date(startedAt)) / 1000 : 0));\nconst transcript = msg.transcript || analysis.transcript || '';\nconst summary = analysis.summary || msg.summary || '';\nconst recordingUrl = msg.recordingUrl || call.recordingUrl || '';\nconst successEval = analysis.successEvaluation || '';\nconst cost = msg.cost || 0;\n\nconst noAnswerReasons = ['no-answer','busy','failed','customer-did-not-answer','voicemail','customer-busy','customer-ended-call-quickly'];\nconst wasAnswered = !noAnswerReasons.some(r => endedReason.toLowerCase().includes(r)) && durationSec > 10;\n\nlet normalizedPhone = (customerPhone || '').trim();\nif (normalizedPhone && !normalizedPhone.startsWith('+')) {\n  const digits = normalizedPhone.replace(/\\D/g,'');\n  normalizedPhone = digits.length === 10 ? '+1' + digits : '+' + digits;\n}\nif (!normalizedPhone && isWebCall) {\n  normalizedPhone = 'web:' + callId.slice(0, 12);\n}\n\nconst extracted = {\n  business_name: norm(structured.business_name || structured.businessName),\n  industry: norm(structured.industry),\n  pain_point: norm(structured.pain_point || structured.painPoint),\n  service_interest: norm(structured.service_interest || structured.serviceInterest),\n  budget: norm(structured.budget),\n  timeline: norm(structured.timeline),\n  num_locations: norm(structured.num_locations || structured.locations),\n  weekly_missed: norm(structured.weekly_missed || structured.weeklyMissed),\n  current_setup: norm(structured.current_setup || structured.currentSetup),\n  booked: structured.booked === true || structured.booked === 'true',\n  qualified: structured.qualified === true || structured.qualified === 'true',\n  escalate: structured.escalate === true || structured.escalate === 'true',\n  escalate_reason: norm(structured.escalate_reason || structured.escalateReason) || '',\n  sentiment: norm(structured.sentiment || analysis.sentiment) || 'neutral',\n  next_action: norm(structured.next_action || structured.nextAction) || ''\n};\n\nreturn [{ json: {\n  skip: false,\n  callId,\n  customerPhone: normalizedPhone,\n  customerName,\n  firstName: (customerName || '').split(' ')[0] || '',\n  startedAt,\n  endedAt,\n  endedReason,\n  durationSec,\n  transcript,\n  summary,\n  recordingUrl,\n  successEval,\n  cost,\n  wasAnswered,\n  extracted,\n  isWebCall,\n  webSource,\n  webPage,\n  assistantId,\n  language\n} }];"
      },
      "id": "852b831e-163b-4e3f-a346-b1e5069b8eb5",
      "name": "Parse Vapi Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -6160,
