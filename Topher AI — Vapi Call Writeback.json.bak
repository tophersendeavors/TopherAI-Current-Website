    {
      "parameters": {
        "method": "POST",
        "url": "={{ $vars.SUPABASE_URL }}/rest/v1/calls",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $vars.SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $vars.SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Prefer",
              "value": "return=minimal"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\n  \"call_id\": $json.callId,\n  \"caller_phone\": $json.customerPhone,\n  \"caller_name\": $json.customerName,\n  \"started_at\": $json.startedAt,\n  \"ended_at\": $json.endedAt,\n  \"duration_seconds\": $json.durationSec,\n  \"ended_reason\": $json.endedReason,\n  \"call_status\": $json.wasAnswered ? \"answered\" : \"no_answer\",\n  \"call_type\": \"inbound\",\n  \"urgency\": $json.extracted.qualified || $json.extracted.booked ? \"hot\" : ($json.extracted.sentiment === \"negative\" ? \"cold\" : \"warm\"),\n  \"transcript\": $json.transcript,\n  \"summary\": $json.summary,\n  \"recording_url\": $json.recordingUrl,\n  \"language\": \"en\",\n  \"sentiment\": $json.extracted.sentiment,\n  \"booked\": $json.extracted.booked,\n  \"inquiry\": $json.extracted.service_interest,\n  \"source\": $json.isWebCall ? (\"vapi_web:\" + ($json.webSource || \"unknown\").replace(\"website_\", \"\")) : \"vapi_phone\"\n} }}",
        "options": {}
      },
      "id": "ae3c2202-4fb9-48c7-976f-9d8c9a900beb",
      "name": "Log Call to Supabase",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
