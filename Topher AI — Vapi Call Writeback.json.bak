      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const data = $input.item.json;\nconst phone = data.customerPhone || '';\nif (!phone || phone.startsWith('web:') || phone.startsWith('unknown')) {\n  console.log('[Phone Guard] Skipping SMS — web call or no phone:', phone);\n  return [];\n}\nconst digits = phone.replace(/\\D/g, '');\nif (digits.length < 10) {\n  console.log('[Phone Guard] Skipping SMS — invalid phone:', phone);\n  return [];\n}\nconsole.log('[Phone Guard] Valid phone, proceeding with SMS:', phone);\nreturn [{ json: data }];"
      },
